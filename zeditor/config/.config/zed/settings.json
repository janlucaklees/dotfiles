      "args": [],
      "projects": [
        {
          "paths": [
            "/home/jlk/./"
          ]
        },
        {
          "paths": [
            "/home/jlk/renaissance/./"
          ]
        },
        {
          "paths": [
            "~/CloudBaby"
          ]
        }
      ]
    },
    {
      "host": "streamingbaby",
      "args": [],
