            "/home/jlk"
          ]
        }
      ]
    },
    {
      "host": "streamingbaby",
      "args": [],
      "projects": []
    },
    {
      "host": "cloud.janlucaklees.de",
      "args": [],
      "projects": []
    },
    {
      "host": "storagebaby",
      "args": [],
